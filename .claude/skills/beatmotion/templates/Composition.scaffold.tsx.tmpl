  Audio,
  Sequence,
  spring,
  useCurrentFrame,
  useVideoConfig,__MEDIA_IMPORT_EXTRA__
} from "remotion";
import beatsData from "__BEATS_IMPORT__";
import { createBeatHelpers } from "./useBeats";
import {
  accentLineWidth,
  cameraDolly,
  chromaticAberration,
  downbeatPulse,
  dropImpact,
  glowAura,
  grainNoise,
  hueShiftFromCentroid,
  kineticLetter,
  parallaxDrift,
