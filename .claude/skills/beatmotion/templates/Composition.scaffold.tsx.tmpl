const helpers = createBeatHelpers(beatsData);

// Palette mapped from the classifier's genre tag. Each entry is a small
// palette of accent colors — the phrase picker cycles through them so
// adjacent phrases get different accents but the overall feel stays
// coherent per song. The bg color is always near-black; we vary the
// warmth (#000 cold, #0A0807 warm-dark) per genre.
const PALETTE_BY_GENRE: Record<string, { accents: string[]; bg: string }> = {
  edm:           { accents: ["#00DC82", "#FF5C5C", "#6E7BFF"], bg: "#000000" },
  house:         { accents: ["#00DC82", "#FFB45C", "#6E7BFF"], bg: "#000000" },
  trap:          { accents: ["#FF5C5C", "#FFB45C", "#6E7BFF"], bg: "#000000" },
  hiphop:        { accents: ["#FFB45C", "#F0F0F0", "#C6A0FF"], bg: "#000000" },
  drum_and_bass: { accents: ["#00DC82", "#FF5C5C", "#FFB45C"], bg: "#000000" },
  pop:           { accents: ["#FF6E8A", "#C6A0FF", "#6EE7FF"], bg: "#000000" },
  rock:          { accents: ["#FF5C5C", "#FFB45C", "#F0F0F0"], bg: "#000000" },
  ballad:        { accents: ["#FFE0B2", "#FFB4A2", "#E5E5E5"], bg: "#0A0808" },
  lofi:          { accents: ["#FFE0B2", "#C6A0FF", "#FFB4A2"], bg: "#0A0807" },
  general:       { accents: ["#6EE7FF", "#C6A0FF", "#FFB45C", "#FF6E8A"], bg: "#000000" },
};
const PALETTE = PALETTE_BY_GENRE[helpers.classification?.genre ?? "general"]
  ?? PALETTE_BY_GENRE.general;

// Sequence boundaries: phrase-based when grid-locked, section-based otherwise.
const SEQUENCE_BOUNDARIES = (() => {
  if (helpers.gridLocked && helpers.phrases.length > 0) {
    return helpers.phrases.map((p, i) => ({
      key: `phrase-${i}`,
      startFrame: p.startFrame,
      endFrame: p.endFrame,
      phraseIndex: i,
      sectionIndex: helpers.sections.findIndex(
        (s) =>
          s.start <= p.startFrame / helpers.fps &&
          p.startFrame / helpers.fps < s.end
      ),
    }));
  }
  return helpers.sections.map((section, i) => {
    const startFrame = Math.round(section.start * helpers.fps);
    const endFrame = Math.round(section.end * helpers.fps);
    return {
      key: `section-${i}`,
      startFrame,
      endFrame,
      phraseIndex: i,
      sectionIndex: i,
    };
  });
})();

export const __COMP_NAME__: React.FC = () => {
  return (
    <AbsoluteFill style={{ background: PALETTE.bg, overflow: "hidden" }}>
      <Audio src="__AUDIO_SRC__" />

      {/* Layer 1: AmbientBg — radial gradient that breathes with energy,
          slowly drifts with intensity, hue-shifts with centroid. */}
      <AmbientBackground />

      {/* Layer 2: Camera group — wraps everything content-related so dropImpact
          + cameraDolly transforms shake/scale the whole composition together. */}
      <CameraGroup>
        {/* Layer 3: AnticipationVignette — edge-darkening during pre-drop
            tension. Composes with vignetteEdge for an always-on subtle vignette. */}
        <AnticipationVignette />

        {/* Layer 4: Per-phrase typography. */}
        {SEQUENCE_BOUNDARIES.map((b) => {
          const durationInFrames = Math.max(1, b.endFrame - b.startFrame);
          return (
            <Sequence
              key={b.key}
              from={b.startFrame}
              durationInFrames={durationInFrames}
            >
              <PhraseView
                phraseIndex={b.phraseIndex}
                sectionIndex={Math.max(0, b.sectionIndex)}
                phraseStartFrame={b.startFrame}
              />
            </Sequence>
          );
        })}
      </CameraGroup>

      {/* Layer 5: Drop flash overlay — full-frame white wash, sits OUTSIDE
          the camera group so it doesn't shake with the impact transform. */}
      <DropFlashOverlay />

      {/* Layer 6: Grain overlay — 3% noise, premium feel, hides banding. */}
      <GrainOverlay />
    </AbsoluteFill>
  );
};

// ─────────────────────────────────────────────────────────────────────────
// LAYERS
// ─────────────────────────────────────────────────────────────────────────

const CameraGroup: React.FC<{ children: React.ReactNode }> = ({ children }) => {
  const frame = useCurrentFrame();
  // Drop impact (discrete, multi-stage) composes with cameraDolly (continuous,
  // intensity-driven). When both active, both transforms apply — drop wins
  // visually because its amplitudes are much larger.
  const drop = helpers.drops.find(
    (d) => frame >= d.frame - 12 && frame <= d.frame + 30
  );
  const impact = drop
    ? dropImpact(frame, drop.frame, { intensity: drop.kind === "main_drop" ? 1 : 0.7 })
    : null;
  const dolly = cameraDolly(helpers.intensityAt(frame), 0.02);
  // If a drop is active, dropImpact's transform dominates; otherwise dolly's.
  const transform = impact ? impact.cameraStyle : dolly;
  return (
    <AbsoluteFill style={transform}>
      {impact ? <AbsoluteFill style={{ pointerEvents: "none", ...impact.vignetteStyle }} /> : null}
      {children}
    </AbsoluteFill>
  );
};

const DropFlashOverlay: React.FC = () => {
  const frame = useCurrentFrame();
  const drop = helpers.drops.find(
    (d) => frame >= d.frame - 12 && frame <= d.frame + 30
  );
  if (!drop) return null;
  const impact = dropImpact(frame, drop.frame, {
    intensity: drop.kind === "main_drop" ? 1 : 0.7,
  });
  return <AbsoluteFill style={{ pointerEvents: "none", ...impact.flashStyle }} />;
};

const AmbientBackground: React.FC = () => {
  const frame = useCurrentFrame();
  const { fps } = useVideoConfig();
  const energy = helpers.energyAt(frame);
  const intensity = helpers.intensityAt(frame);
  const centroid = helpers.centroidAt(frame);
  const subBass = helpers.subBassAt(frame);

  // Slow continuous parallax drift on the gradient itself. Modulated by
  // intensity so quiet passages drift gently and loud passages move more.
  const drift = parallaxDrift(frame, fps, intensity, { speed: 0.25, maxPx: 20, axis: "xy" });

  // Downbeat pulse adds a brief brightening on each bar-1.
  const lastDownbeat = (() => {
    for (let i = helpers.beats.length - 1; i >= 0; i--) {
      if (helpers.beats[i].downbeat && helpers.beats[i].frame <= frame) {
        return helpers.beats[i].frame;
      }
    }
    return null;
  })();
  const pulse = downbeatPulse(frame, lastDownbeat, { peak: 0.05 });
  // Energy adds a baseline brightening; sub-bass adds a low warm glow.
  const innerBrightness = 0.06 + energy * 0.06 + pulse;
  const warmth = subBass * 0.05; // adds slight orange when sub hits

  const hue = hueShiftFromCentroid(centroid, { degMax: 6 });

  const bg = `radial-gradient(circle at 50% 45%, rgba(255,${Math.round(255 - warmth * 80)},${Math.round(255 - warmth * 160)},${innerBrightness.toFixed(3)}) 0%, transparent 60%)`;
  return (
    <AbsoluteFill style={{ ...drift, ...hue }}>
      <AbsoluteFill style={{ background: bg }} />
    </AbsoluteFill>
  );
};

const AnticipationVignette: React.FC = () => {
  const frame = useCurrentFrame();
  // Always-on subtle edge vignette + tension-driven darkening.
  const tension = helpers.tensionAt(frame);
  const base = vignetteEdge(0.35, { maxOpacity: 0.5 }); // baseline
  const tensionAdd = vignetteEdge(tension, { maxOpacity: 0.35 });
  return (
    <>
      <AbsoluteFill style={{ pointerEvents: "none", ...base }} />
      <AbsoluteFill style={{ pointerEvents: "none", ...tensionAdd }} />
    </>
  );
};

const GrainOverlay: React.FC = () => {
  // Single static SVG noise pattern. Cheap; doesn't recompute per frame.
  return (
    <AbsoluteFill
      style={{
        pointerEvents: "none",
        opacity: 0.04,
        mixBlendMode: "overlay",
        ...grainNoise(0.4, 11),
      }}
    />
  );
};

const PhraseView: React.FC<{
  phraseIndex: number;
  sectionIndex: number;
  phraseStartFrame: number;
}> = ({ phraseIndex, sectionIndex, phraseStartFrame }) => {
  const frame = useCurrentFrame();
  const { fps } = useVideoConfig();
  const section = helpers.sections[sectionIndex];

  const accentColor = PALETTE.accents[phraseIndex % PALETTE.accents.length];

  // Spring reveal progress for the phrase. Slow stiffness → gentle settle.
  const localFrame = frame - phraseStartFrame;
  const reveal = spring({
    frame: Math.max(0, localFrame),
    fps,
    config: { damping: 22, stiffness: 75, mass: 1 },
  });

  // Continuous drivers for the typography stack.
  const tension = helpers.tensionAt(frame);
  const subBass = helpers.subBassAt(frame);
  const energy = helpers.energyAt(frame);

  const title = section ? section.kind.toUpperCase() : "BEATMOTION";
  const totalPhrases = SEQUENCE_BOUNDARIES.length;

  __MEDIA_RENDER_BLOCK__
};
