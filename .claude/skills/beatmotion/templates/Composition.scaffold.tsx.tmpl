import {
  AbsoluteFill,
  Audio,
  Sequence,
  spring,
  useCurrentFrame,
  useVideoConfig,__MEDIA_IMPORT_EXTRA__
} from "remotion";
import beatsData from "__BEATS_IMPORT__";
import { createBeatHelpers } from "./useBeats";
import {
  accentLineWidth,
  downbeatPulse,
  dropImpact,
  kineticLetter,
} from "./transitions";
__MEDIA_FILES_IMPORT__

const helpers = createBeatHelpers(beatsData);

// Restrained palette that cycles per phrase. Title/promo aesthetic: white
// text on near-black with a single accent color drawing the eye.
const ACCENT_COLORS = ["#6EE7FF", "#C6A0FF", "#FFB45C", "#FF6E8A"];

// Pre-compute Sequence boundaries from phrases (if grid-locked) or sections.
// One Sequence per phrase keeps the visual content stable for ~16 beats at
// a time, so the eye isn't being asked to re-anchor every beat.
const SEQUENCE_BOUNDARIES = (() => {
  if (helpers.gridLocked && helpers.phrases.length > 0) {
    return helpers.phrases.map((p, i) => ({
      key: `phrase-${i}`,
      startFrame: p.startFrame,
      endFrame: p.endFrame,
      phraseIndex: i,
      sectionIndex: helpers.sections.findIndex(
        (s) =>
          s.start <= p.startFrame / helpers.fps &&
          p.startFrame / helpers.fps < s.end
      ),
    }));
  }
  return helpers.sections.map((section, i) => {
    const startFrame = Math.round(section.start * helpers.fps);
    const endFrame = Math.round(section.end * helpers.fps);
    return {
      key: `section-${i}`,
      startFrame,
      endFrame,
      phraseIndex: i,
      sectionIndex: i,
    };
  });
})();

export const __COMP_NAME__: React.FC = () => {
  return (
    <AbsoluteFill style={{ overflow: "hidden", background: "#050507" }}>
      <Audio src="__AUDIO_SRC__" />

      {/* Outer wrapper holds drop-impact camera shake + scale. */}
      <DropCameraWrap>
        <BackgroundLayer />
        {SEQUENCE_BOUNDARIES.map((b) => {
          const durationInFrames = Math.max(1, b.endFrame - b.startFrame);
          return (
            <Sequence
              key={b.key}
              from={b.startFrame}
              durationInFrames={durationInFrames}
            >
              <PhraseView
                phraseIndex={b.phraseIndex}
                sectionIndex={Math.max(0, b.sectionIndex)}
                phraseStartFrame={b.startFrame}
              />
            </Sequence>
          );
        })}
      </DropCameraWrap>

      {/* Flash + vignette overlays live OUTSIDE the camera-wrapped tree so
          they don't inherit its scale/shake — they're fullscreen washes. */}
      <DropFlashOverlay />
    </AbsoluteFill>
  );
};

const DropCameraWrap: React.FC<{ children: React.ReactNode }> = ({ children }) => {
  const frame = useCurrentFrame();
  // Apply the nearest drop's camera shake + scale to everything inside.
  // Only one drop is "active" at a time (within its ±30-frame window).
  const drop = helpers.drops.find(
    (d) => frame >= d.frame - 12 && frame <= d.frame + 30
  );
  const impact = drop ? dropImpact(frame, drop.frame, { intensity: drop.kind === "main_drop" ? 1 : 0.7 }) : null;
  return (
    <AbsoluteFill style={impact?.cameraStyle ?? {}}>
      {/* anticipation vignette dims everything just before the hit. */}
      {impact ? <AbsoluteFill style={{ pointerEvents: "none", ...impact.vignetteStyle }} /> : null}
      {children}
    </AbsoluteFill>
  );
};

const DropFlashOverlay: React.FC = () => {
  const frame = useCurrentFrame();
  const drop = helpers.drops.find(
    (d) => frame >= d.frame - 12 && frame <= d.frame + 30
  );
  if (!drop) return null;
  const impact = dropImpact(frame, drop.frame, { intensity: drop.kind === "main_drop" ? 1 : 0.7 });
  return <AbsoluteFill style={{ pointerEvents: "none", ...impact.flashStyle }} />;
};

const BackgroundLayer: React.FC = () => {
  const frame = useCurrentFrame();
  // Radial gradient that brightens 4% on each downbeat then decays.
  // Subtle enough that the user perceives "breathing" without anything
  // moving visibly — fills the no-motion gaps between phrase boundaries.
  const lastDownbeat = (() => {
    for (let i = helpers.beats.length - 1; i >= 0; i--) {
      if (helpers.beats[i].downbeat && helpers.beats[i].frame <= frame) {
        return helpers.beats[i].frame;
      }
    }
    return null;
  })();
  const pulse = downbeatPulse(frame, lastDownbeat);
  const bg = `radial-gradient(circle at 50% 45%, rgba(255,255,255,${(0.05 + pulse).toFixed(3)}) 0%, transparent 65%), #050507`;
  return <AbsoluteFill style={{ background: bg }} />;
};

const PhraseView: React.FC<{
  phraseIndex: number;
  sectionIndex: number;
  phraseStartFrame: number;
}> = ({ phraseIndex, sectionIndex, phraseStartFrame }) => {
  const frame = useCurrentFrame();
  const { fps } = useVideoConfig();
  const section = helpers.sections[sectionIndex];
  const accentColor = ACCENT_COLORS[phraseIndex % ACCENT_COLORS.length];

  // Reveal progress for the phrase: spring from 0 to 1 over the first
  // ~30 frames of the phrase. All title content uses this as its master
  // timing variable.
  const localFrame = frame - phraseStartFrame;
  const reveal = spring({
    frame: Math.max(0, localFrame),
    fps,
    config: { damping: 18, stiffness: 80, mass: 0.9 },
  });

  const title = section ? section.kind.toUpperCase() : "BEATMOTION";
  const totalPhrases = SEQUENCE_BOUNDARIES.length;

  __MEDIA_RENDER_BLOCK__
};
